# Backtest sweep output
backtest-engine/research/output/sweeps/

# Per-research-dir output artifacts (CSVs, .txt logs, candidate JSONs).
# Regeneratable from the scripts in the same research dir; bloats git and
# routinely produces >100MB files that GitHub will reject. The scripts and
# SUMMARY.md stay tracked — only the output/ subdir is ignored. Files
# already tracked from older research dirs (e.g. first-hour, ls-overlay)
# stay tracked; this rule only affects new additions.
backtest-engine/research/*/output/

# Skunkworks projects
skunkworks/
# Greenfield: regenerable caches and binary artifacts (masters live in backtest-engine/data/)
backtest-engine/greenfield/**/__pycache__/
backtest-engine/greenfield/**/*.npz
backtest-engine/greenfield/**/*.pkl
backtest-engine/greenfield/explore/cache/
backtest-engine/greenfield/explore/cache_*
backtest-engine/greenfield/explore/C1-touches.csv.gz
backtest-engine/greenfield/explore/R1-oi-cache.csv
