//@version=6
indicator("GEX Levels", overlay=true, max_lines_count=500, max_labels_count=500)

// ============================================================================
// GEX LEVELS INDICATOR
// Displays Gamma Exposure levels from Schwab options data
// Paste 13-value CSV: zero_gamma,call_wall,put_wall,r1-r5,s1-s5
// ============================================================================

// === INPUT GROUPS ===
g_data = "Data Entry"
g_magnets = "Gamma Magnets"
g_style = "Style Settings"

// === CSV DATA ENTRY ===
// Format: zero_gamma,call_wall,put_wall,r1,r2,r3,r4,r5,s1,s2,s3,s4,s5
i_csvData = input.string("", "Paste CSV Data", group=g_data,
     tooltip="13 values: zero_gamma,call_wall,put_wall,r1,r2,r3,r4,r5,s1,s2,s3,s4,s5")

// === GAMMA MAGNETS (optional) ===
i_showMagnets = input.bool(false, "Show Gamma Magnets", group=g_magnets)
i_m1 = input.float(0, "Magnet 1", group=g_magnets)
i_m2 = input.float(0, "Magnet 2", group=g_magnets)
i_m3 = input.float(0, "Magnet 3", group=g_magnets)

// === STYLE SETTINGS ===
i_showLabels = input.bool(true, "Show Labels", group=g_style)
i_extendLines = input.string("right", "Extend Lines", options=["none", "left", "right", "both"], group=g_style)
i_lineWidth = input.int(1, "Line Width", minval=1, maxval=4, group=g_style)

i_zeroGammaColor = input.color(color.yellow, "Zero Gamma", group=g_style)
i_callWallColor = input.color(color.new(color.red, 40), "Call Wall", group=g_style)
i_putWallColor = input.color(color.new(color.green, 10), "Put Wall", group=g_style)
i_resistColor = input.color(color.new(color.orange, 50), "Resistance", group=g_style)
i_supportColor = input.color(color.new(color.lime, 20), "Support", group=g_style)
i_magnetColor = input.color(color.new(color.white, 70), "Magnet Color", group=g_style)

// === ARRAYS TO STORE DRAWING OBJECTS ===
var array<line> gexLines = array.new<line>()
var array<label> gexLabels = array.new<label>()

// === CSV PARSING ===
var float csv_zeroGamma = na, var float csv_callWall = na, var float csv_putWall = na
var float csv_r1 = na, var float csv_r2 = na, var float csv_r3 = na, var float csv_r4 = na, var float csv_r5 = na
var float csv_s1 = na, var float csv_s2 = na, var float csv_s3 = na, var float csv_s4 = na, var float csv_s5 = na

if barstate.isfirst and str.length(i_csvData) > 0
    parts = str.split(i_csvData, ",")
    if array.size(parts) >= 13
        csv_zeroGamma := str.tonumber(array.get(parts, 0))
        csv_callWall := str.tonumber(array.get(parts, 1))
        csv_putWall := str.tonumber(array.get(parts, 2))
        csv_r1 := str.tonumber(array.get(parts, 3))
        csv_r2 := str.tonumber(array.get(parts, 4))
        csv_r3 := str.tonumber(array.get(parts, 5))
        csv_r4 := str.tonumber(array.get(parts, 6))
        csv_r5 := str.tonumber(array.get(parts, 7))
        csv_s1 := str.tonumber(array.get(parts, 8))
        csv_s2 := str.tonumber(array.get(parts, 9))
        csv_s3 := str.tonumber(array.get(parts, 10))
        csv_s4 := str.tonumber(array.get(parts, 11))
        csv_s5 := str.tonumber(array.get(parts, 12))

// === HELPER FUNCTION: Get line extension ===
getExtend() =>
    switch i_extendLines
        "none" => extend.none
        "left" => extend.left
        "right" => extend.right
        "both" => extend.both
        => extend.right

// === CLEANUP FUNCTION: Remove all existing lines and labels ===
clearAll() =>
    if array.size(gexLines) > 0
        for i = 0 to array.size(gexLines) - 1
            line.delete(array.get(gexLines, i))
        array.clear(gexLines)

    if array.size(gexLabels) > 0
        for i = 0 to array.size(gexLabels) - 1
            label.delete(array.get(gexLabels, i))
        array.clear(gexLabels)

// === HELPER FUNCTION: Draw level ===
drawLevel(float price, color lineColor, string labelText) =>
    if price > 0 and not na(price)
        newLine = line.new(bar_index - 50, price, bar_index + 10, price,
                          xloc=xloc.bar_index, extend=getExtend(),
                          color=lineColor, width=i_lineWidth)
        array.push(gexLines, newLine)

        if i_showLabels
            newLabel = label.new(bar_index + 5, price, labelText,
                               xloc=xloc.bar_index, yloc=yloc.price,
                               color=color.new(lineColor, 80), textcolor=lineColor,
                               style=label.style_label_left, size=size.small)
            array.push(gexLabels, newLabel)

// === DRAW LEVELS (only on last bar to avoid duplicates) ===
if barstate.islast
    clearAll()

    drawLevel(csv_zeroGamma, i_zeroGammaColor, "Zero Gamma")
    drawLevel(csv_callWall, i_callWallColor, "Call Wall")
    drawLevel(csv_putWall, i_putWallColor, "Put Wall")
    drawLevel(csv_r1, color.new(i_resistColor, 30), "R1")
    drawLevel(csv_r2, color.new(i_resistColor, 30), "R2")
    drawLevel(csv_r3, color.new(i_resistColor, 30), "R3")
    drawLevel(csv_r4, color.new(i_resistColor, 30), "R4")
    drawLevel(csv_r5, color.new(i_resistColor, 30), "R5")
    drawLevel(csv_s1, color.new(i_supportColor, 30), "S1")
    drawLevel(csv_s2, color.new(i_supportColor, 30), "S2")
    drawLevel(csv_s3, color.new(i_supportColor, 30), "S3")
    drawLevel(csv_s4, color.new(i_supportColor, 30), "S4")
    drawLevel(csv_s5, color.new(i_supportColor, 30), "S5")

    if i_showMagnets
        drawLevel(i_m1, color.new(i_magnetColor, 50), "Mag")
        drawLevel(i_m2, color.new(i_magnetColor, 50), "Mag")
        drawLevel(i_m3, color.new(i_magnetColor, 50), "Mag")

// === PLOT VALUES FOR PRICE SCALE ===
plot(csv_zeroGamma > 0 ? csv_zeroGamma : na, "Zero Gamma", color=color.new(i_zeroGammaColor, 90), linewidth=1, display=display.price_scale)
plot(csv_callWall > 0 ? csv_callWall : na, "Call Wall", color=color.new(i_callWallColor, 90), linewidth=1, display=display.price_scale)
plot(csv_putWall > 0 ? csv_putWall : na, "Put Wall", color=color.new(i_putWallColor, 90), linewidth=1, display=display.price_scale)
plot(csv_r1 > 0 ? csv_r1 : na, "R1", color=color.new(i_resistColor, 90), linewidth=1, display=display.price_scale)
plot(csv_r2 > 0 ? csv_r2 : na, "R2", color=color.new(i_resistColor, 90), linewidth=1, display=display.price_scale)
plot(csv_r3 > 0 ? csv_r3 : na, "R3", color=color.new(i_resistColor, 90), linewidth=1, display=display.price_scale)
plot(csv_r4 > 0 ? csv_r4 : na, "R4", color=color.new(i_resistColor, 90), linewidth=1, display=display.price_scale)
plot(csv_r5 > 0 ? csv_r5 : na, "R5", color=color.new(i_resistColor, 90), linewidth=1, display=display.price_scale)
plot(csv_s1 > 0 ? csv_s1 : na, "S1", color=color.new(i_supportColor, 90), linewidth=1, display=display.price_scale)
plot(csv_s2 > 0 ? csv_s2 : na, "S2", color=color.new(i_supportColor, 90), linewidth=1, display=display.price_scale)
plot(csv_s3 > 0 ? csv_s3 : na, "S3", color=color.new(i_supportColor, 90), linewidth=1, display=display.price_scale)
plot(csv_s4 > 0 ? csv_s4 : na, "S4", color=color.new(i_supportColor, 90), linewidth=1, display=display.price_scale)
plot(csv_s5 > 0 ? csv_s5 : na, "S5", color=color.new(i_supportColor, 90), linewidth=1, display=display.price_scale)
